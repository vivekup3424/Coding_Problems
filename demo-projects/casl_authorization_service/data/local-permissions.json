{
  "home_admin": [
    {
      "action": ["read", "write", "configure", "control"],
      "subject": "device",
      "conditions": {
        "homeId": { "$eq": "${user.profile.homeId}" }
      }
    },
    {
      "action": ["read", "write", "configure"],
      "subject": "room",
      "conditions": {
        "homeId": { "$eq": "${user.profile.homeId}" }
      }
    },
    {
      "action": ["read", "control"],
      "subject": "automation",
      "conditions": {
        "homeId": { "$eq": "${user.profile.homeId}" }
      }
    },
    {
      "action": ["read", "control"],
      "subject": "scene",
      "conditions": {
        "homeId": { "$eq": "${user.profile.homeId}" }
      }
    },
    {
      "action": ["read", "write"],
      "subject": "local_settings",
      "conditions": {
        "homeId": { "$eq": "${user.profile.homeId}" }
      }
    },
    {
      "action": ["read", "control"],
      "subject": "security_system",
      "conditions": {
        "homeId": { "$eq": "${user.profile.homeId}" }
      }
    },
    {
      "action": "read",
      "subject": "sensor_data",
      "conditions": {
        "homeId": { "$eq": "${user.profile.homeId}" }
      }
    }
  ],
  "user_002": [
    {
      "action": ["read", "control"],
      "subject": "device",
      "conditions": {
        "homeId": { "$eq": "${user.profile.homeId}" },
        "type": { "$in": ["smart_light", "smart_thermostat", "smart_speaker"] },
        "roomId": { "$in": ["room_001", "room_002"] },
        "timeRestrictions": {
          "startTime": { "$gte": "07:00" },
          "endTime": { "$lte": "23:00" }
        }
      }
    },
    {
      "action": "read",
      "subject": "room",
      "conditions": {
        "id": { "$in": ["room_001", "room_002", "room_004"] }
      }
    },
    {
      "action": "control",
      "subject": "scene",
      "conditions": {
        "homeId": { "$eq": "${user.profile.homeId}" },
        "type": { "$in": ["lighting", "entertainment"] }
      }
    }
  ],
  "user_003": [
    {
      "action": ["read", "control"],
      "subject": "device",
      "conditions": {
        "homeId": { "$eq": "${user.profile.homeId}" },
        "type": { "$in": ["smart_light", "smart_switch"] },
        "roomId": { "$in": ["room_001", "room_003"] },
        "timeRestrictions": {
          "startTime": { "$gte": "18:00" },
          "endTime": { "$lte": "22:00" }
        }
      }
    },
    {
      "action": "read",
      "subject": "room",
      "conditions": {
        "homeId": { "$eq": "${user.profile.homeId}" },
        "id": { "$in": ["room_001", "room_003"] }
      }
    },
    {
      "action": "control",
      "subject": "scene",
      "conditions": {
        "homeId": { "$eq": "${user.profile.homeId}" },
        "type": { "$in": ["lighting"] },
        "roomIds": { "$in": ["room_001", "room_003"] }
      }
    }
  ],
  "user_006": [
    {
      "action": ["read", "control"],
      "subject": "device",
      "conditions": {
        "homeId": { "$eq": "${user.profile.homeId}" },
        "type": { "$in": ["smart_light", "smart_thermostat", "smart_speaker", "smart_switch"] },
        "timeRestrictions": {
          "startTime": { "$gte": "06:00" },
          "endTime": { "$lte": "24:00" }
        }
      }
    },
    {
      "action": "read",
      "subject": "room",
      "conditions": {
        "homeId": { "$eq": "${user.profile.homeId}" }
      }
    },
    {
      "action": "control",
      "subject": "scene",
      "conditions": {
        "homeId": { "$eq": "${user.profile.homeId}" },
        "type": { "$in": ["lighting", "entertainment"] }
      }
    },
    {
      "action": "read",
      "subject": "sensor_data",
      "conditions": {
        "homeId": { "$eq": "${user.profile.homeId}" },
        "type": { "$in": ["motion_sensor"] },
        "roomId": { "$in": ["room_001", "room_002"] }
      }
    }
  ],
  "user_008": [
    {
      "action": ["read", "control"],
      "subject": "device",
      "conditions": {
        "homeId": { "$eq": "${user.profile.homeId}" },
        "type": { "$in": ["smart_light"] },
        "roomId": { "$in": ["room_002"] },
        "timeRestrictions": {
          "startTime": { "$gte": "08:00" },
          "endTime": { "$lte": "20:00" }
        }
      }
    },
    {
      "action": "read",
      "subject": "room",
      "conditions": {
        "homeId": { "$eq": "${user.profile.homeId}" },
        "id": { "$in": ["room_002"] }
      }
    },
    {
      "action": "control",
      "subject": "scene",
      "conditions": {
        "homeId": { "$eq": "${user.profile.homeId}" },
        "type": { "$in": ["lighting"] },
        "roomIds": { "$in": ["room_002"] }
      }
    }
  ],
  "user_010": [
    {
      "action": ["read", "control"],
      "subject": "device",
      "conditions": {
        "homeId": { "$eq": "${user.profile.homeId}" },
        "type": { "$in": ["smart_light", "smart_speaker"] },
        "roomId": { "$in": ["room_001", "room_004"] },
        "timeRestrictions": {
          "startTime": { "$gte": "09:00" },
          "endTime": { "$lte": "21:00" }
        }
      }
    },
    {
      "action": "read",
      "subject": "room",
      "conditions": {
        "homeId": { "$eq": "${user.profile.homeId}" },
        "id": { "$in": ["room_001", "room_004"] }
      }
    },
    {
      "action": "control",
      "subject": "scene",
      "conditions": {
        "homeId": { "$eq": "${user.profile.homeId}" },
        "type": { "$in": ["lighting", "entertainment"] },
        "roomIds": { "$in": ["room_001"] }
      }
    }
  ],
  "emergency_override": [
    {
      "action": ["read", "control"],
      "subject": "device",
      "conditions": {
        "type": { "$in": ["alarm_system", "door_lock", "smart_light"] },
        "emergency": { "$eq": true }
      }
    },
    {
      "action": "control",
      "subject": "scene",
      "conditions": {
        "type": { "$in": ["emergency_lighting", "emergency_unlock"] }
      }
    }
  ]
}
